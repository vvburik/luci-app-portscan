{
	"luci-app-portscan": {
		"description": "Portscan protection",
		"read": {
			"uci": [ "portscan" ],
			"ubus": {
				"luci": [ "getVersion" ],
				"file": [ "exec" ]
			}
		},
		"write": {
			"uci": [ "portscan" ],
			"file": {
				"/usr/sbin/nft": [ "exec" ],
				"/etc/init.d/portscan": [ "exec" ]
			}
		}
	}
}
